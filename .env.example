# Regulon environment overrides.
# Every value has a sane default; nothing here is required for the local-first path.
# Settings use the REGULON_ prefix and override config/regulon.yaml.

# Runtime environment name: dev | ci | prod
REGULON_ENVIRONMENT=dev

# Root directory for local data (knowledge base, queues, audit log)
REGULON_DATA_DIR=./data

# --- Arrive in later milestones (documented early, all optional) ---
# OLLAMA_HOST=http://localhost:11434        # M3: local model gateway default
# OPENAI_API_KEY=                           # M3: optional cloud provider
# ANTHROPIC_API_KEY=                        # M3: optional cloud provider
